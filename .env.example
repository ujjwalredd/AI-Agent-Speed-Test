# PostgreSQL connection string (Prisma). Works locally and on Vercel.
# Get a free serverless Postgres at https://neon.tech (or Vercel Postgres / Supabase).
# Use the DIRECT (non-pooled) connection string so `prisma db push` works in the build.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Per-request request timeout in milliseconds (optional; default 60000)
DEFAULT_TIMEOUT_MS=60000

# Optional: a server-side default Anthropic API key.
# If set, users can run real benchmarks without pasting their own key.
# NEVER commit a real key. The key is only used server-side and is never
# returned to the frontend or written to the database.
# ANTHROPIC_API_KEY=sk-ant-...

# Secret for the encrypted API-key vault (AES-256-GCM). REQUIRED in production
# (e.g. set it in the Vercel dashboard). Any string works (hashed to 32 bytes).
# Generate one with: openssl rand -hex 32
# In local dev, a random secret is auto-generated into .key-vault-secret if unset.
KEY_VAULT_SECRET="change-me-openssl-rand-hex-32"
