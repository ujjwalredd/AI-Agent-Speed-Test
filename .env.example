# All environment variables are OPTIONAL — the app runs with none set.

# Per-request timeout in milliseconds (default 60000).
DEFAULT_TIMEOUT_MS=60000

# Optional server-side default Anthropic API key. If set, users can run live
# benchmarks without pasting their own key. Never commit a real key; it is used
# only server-side and is never returned to the frontend.
# ANTHROPIC_API_KEY=sk-ant-...
